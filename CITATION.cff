    authors:
      - family-names: "Anderson"
        given-names: "Jeffrey"
    title: "Make Eigenvalues Resonate: A Coupled Oscillator Project for Lower-Division Linear Algebra"
    journal: "PRIMUS"
    year: 2018
    doi: "10.1080/10511970.2018.1484400"
  - type: article
    authors:
      - family-names: "Anderson"
